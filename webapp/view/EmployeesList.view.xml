<mvc:View id="employeesList" controllerName="stk.starterkit.controller.EmployeesList"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">
    <Page title="{i18n>title}" showNavButton="true" navButtonPress="handleNavButtonPress">
        <content>            
            <Button id="goToCustomers" text="Open Customers List" press="onGoToCustomersList" icon="sap-icon://customer"/>
            <!-- Normally i would aggregate Orders inside items parameters, but it seems it is not available in odatav2 -->
            <Table 
                id="employeesTable" 
                items="{path:'/Employees', 
                    parameters:{
                        select:'EmployeeID,LastName,FirstName,Title,Orders/OrderID', 
                        expand:'Orders'
                    }
                }" 
                class="blueHeaderText">
                <headerToolbar>
                    <OverflowToolbar >
                        <Title text="{i18n>EmployeesTableHeader}" level="H2"/>
                        <!-- <ToolbarSpacer/>
                        <Button text="" press=""/> -->
                    </OverflowToolbar>
                </headerToolbar>
                <columns>
                    <Column>
                        <Label text="{i18n>contactName}"/>
                    </Column>
                    <Column>
                        <Label text="{i18n>employeeTitle}"/>
                    </Column>
                    <Column>
                        <Label text="{i18n>orders}"/>
                    </Column>
                    <Column>
                        <Label text="{i18n>actions}"/>
                    </Column>
                </columns>
                <items>
                    <ColumnListItem>
                        <Text text="{FirstName} {LastName}"/>
                        <Text text="{Title}"/>
                        <!-- Here i decided to use formatter, because odatav2 does not seem to have aggregations -->
                        <Text text="{path: 'Orders', formatter: '.formatter.formatEmployeeOrders'}"/>
                        <FlexBox gap="0.5rem">
                            <Button text="{i18n>motivateAction}" press="onMotivate"/>
                            <Button text="{i18n>fireAction}" press="onFire"/>
                        </FlexBox>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
    </Page>
    
</mvc:View>
